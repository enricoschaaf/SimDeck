{
  "name": "react-native-simdeck",
  "version": "0.1.3",
  "description": "Debug-only React Native runtime inspector for SimDeck",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NativeScript/SimDeck",
    "directory": "packages/react-native-inspector"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "react-native": "./src/auto.ts",
      "default": "./dist/auto.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "files": [
    "dist",
    "ios",
    "src",
    "README.md",
    "simdeck-react-native-inspector.podspec"
  ],
  "keywords": [
    "react-native",
    "inspector",
    "simdeck"
  ],
  "sideEffects": [
    "./src/auto.ts",
    "./dist/auto.js"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "typescript": "~5.8.0"
  }
}
